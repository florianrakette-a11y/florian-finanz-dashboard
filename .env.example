# ---------------------------------------------------------------------------
# Vorlage für Umgebungsvariablen. KEINE echten Werte hier eintragen!
# Diese Datei wird committet und dient nur als Doku, welche Variablen es gibt.
# Echte Werte gehören in .env.local (wird NICHT committet, siehe .gitignore).
# ---------------------------------------------------------------------------

# --- Supabase ---
# Project Settings -> API in der Supabase-Oberfläche
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Geheimer Schlüssel (sb_secret_...): erst ab Phase 5 (Bank-/E-Mail-Sync) nötig.
SUPABASE_SECRET_KEY=

# --- Buchhaltungsbutler (Phase 5) ---
BB_API_CLIENT=
BB_API_SECRET=
BB_API_KEY=

# --- Google OAuth: Gmail + Drive (Phase 6 / 8) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- IMAP Strato (Phase 7) – NUR lesend (FETCH/SELECT), keine Schreib-/Löschbefehle ---
IMAP_HOST=imap.strato.de
IMAP_PORT=993
IMAP_RAKETONE_USER=info@raketone.com
IMAP_RAKETONE_PASSWORD=
IMAP_SPINNRAT_USER=florian@spinnrat.de
IMAP_SPINNRAT_PASSWORD=

# --- Claude API: Vision + Klassifikation (Phase 4 / 6) ---
ANTHROPIC_API_KEY=
